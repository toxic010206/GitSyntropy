# GitSyntropy Backend — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env.

GS_APP_NAME=GitSyntropy API
GS_APP_VERSION=0.1.0
GS_API_PREFIX=/api/v1

# CORS — set to your Vercel domain in production
GS_FRONTEND_URL=http://localhost:4321

GS_JWT_SECRET=your-random-secret-here
GS_JWT_ALGORITHM=HS256
GS_JWT_EXP_MINUTES=60
GS_JWT_ISSUER=gitsyntropy-local

# GitHub OAuth App (https://github.com/settings/developers)
# In production: redirect URL must be https://<vercel-domain>/auth
GS_GITHUB_CLIENT_ID=Iv23li7hELkVsoXUxaN8
GS_GITHUB_CLIENT_SECRET=your_github_client_secret
GS_GITHUB_REDIRECT_URL=http://localhost:4321/auth
GS_GITHUB_SCOPE=read:user user:email

# Optional: server-side PAT for GitHub API calls in /github/sync
GS_GITHUB_ACCESS_TOKEN=

GS_ANTHROPIC_API_KEY=sk-ant-...
GS_ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase: Settings → Database → Database password
GS_DATABASE_URL=postgresql+asyncpg://postgres:[DB_PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# Superadmin — GitHub handle that can access /api/v1/admin/*
GS_SUPERADMIN_GITHUB_HANDLE=1mystic
GS_SUPERADMIN_EMAIL=23f2004201@ss.com
