# ── Local dev (copy to .env) ─────────────────────────────────────────────
PUBLIC_API_BASE=http://localhost:8000/api/v1
PUBLIC_WS_BASE=ws://localhost:8000

# false in dev so you can browse without signing in
PUBLIC_AUTH_REQUIRED=false

# When AUTH_REQUIRED=true, show demo data to guests instead of hard-blocking
PUBLIC_GUEST_TRIAL=true

# Fallback user_id used when AUTH_REQUIRED=false (dev only)
PUBLIC_AUTH_BYPASS_USER_ID=user_local

# ── Production (Vercel) — set via Vercel dashboard, not in this file ─────
# PUBLIC_API_BASE=https://gitsyntropy-api.up.railway.app/api/v1
# PUBLIC_WS_BASE=wss://gitsyntropy-api.up.railway.app
# PUBLIC_AUTH_REQUIRED=true
# PUBLIC_GUEST_TRIAL=true
