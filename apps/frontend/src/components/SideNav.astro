---
import { NavUser } from "@/components/NavUser";
import { GlobalTeamSelector } from "@/components/GlobalTeamSelector";

const links = [
  { href: "/dashboard", label: "Dashboard", icon: "dashboard" },
  { href: "/workspace", label: "Workspace", icon: "schema" },
  { href: "/compatibility", label: "Compatibility", icon: "compare_arrows" },
  { href: "/assessment", label: "Assessment", icon: "psychology" },
  { href: "/insights", label: "Insights", icon: "insights" },
  { href: "/guide", label: "Guide", icon: "menu_book" },
];

const path = Astro.url.pathname;
---

<!-- Mobile bookmark toggle tab -->
<button
  id="nav-toggle"
  class="lg:hidden fixed top-1/2 -translate-y-1/2 left-0 z-[60] flex flex-col items-center justify-center gap-1 w-5 py-4 rounded-r-lg bg-[#080808]/95 border border-l-0 border-white/12 text-gray-400 hover:text-primary backdrop-blur-md transition-[left] duration-300 shadow-lg"
  aria-label="Toggle menu"
>
  <span id="nav-toggle-icon" class="material-symbols-outlined text-[14px] leading-none">chevron_right</span>
</button>

<!-- Backdrop -->
<div
  id="nav-backdrop"
  class="lg:hidden fixed inset-0 z-[49] bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- Sidebar -->
<nav
  id="side-nav"
  class="fixed left-0 top-0 bottom-0 w-[220px] z-50 flex flex-col bg-[#080808]/95 backdrop-blur-md border-r border-white/8 transition-transform duration-300 -translate-x-full lg:translate-x-0"
>
  <!-- Logo -->
  <div class="px-4 pt-6 pb-5">
    <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight text-white hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-primary">psychology</span>
      <span class="font-display">GitSyntropy</span>
    </a>
  </div>

  <div class="mx-4 border-t border-white/8 mb-3"></div>

  <!-- Nav links -->
  <div class="flex-1 flex flex-col gap-0.5 px-3">
    {links.map((link) => {
      const active = path === link.href || path.startsWith(link.href + '/');
      return (
        <a
          href={link.href}
          class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all ${
            active
              ? 'bg-primary/12 text-primary border border-primary/20'
              : 'text-gray-500 hover:text-white hover:bg-white/6 border border-transparent'
          }`}
        >
          <span class={`material-symbols-outlined text-[20px] flex-shrink-0 ${active ? 'text-primary' : ''}`}>{link.icon}</span>
          {link.label}
        </a>
      );
    })}
  </div>

  <!-- User section (session-aware) -->
  <NavUser client:load />
</nav>

<!-- Floating global team selector (top-right, above all content) -->
<GlobalTeamSelector client:load />

<script>
  const nav = document.getElementById('side-nav');
  const backdrop = document.getElementById('nav-backdrop');
  const toggleBtn = document.getElementById('nav-toggle');
  const toggleIcon = document.getElementById('nav-toggle-icon');
  let isOpen = false;

  function open() {
    isOpen = true;
    nav?.classList.remove('-translate-x-full');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    // Shift tab to sit flush with the sidebar edge
    if (toggleBtn) toggleBtn.style.left = '220px';
    if (toggleIcon) toggleIcon.textContent = 'chevron_left';
  }

  function close() {
    isOpen = false;
    nav?.classList.add('-translate-x-full');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    if (toggleBtn) toggleBtn.style.left = '0px';
    if (toggleIcon) toggleIcon.textContent = 'chevron_right';
  }

  toggleBtn?.addEventListener('click', () => isOpen ? close() : open());
  backdrop?.addEventListener('click', close);
</script>
