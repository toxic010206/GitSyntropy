---
import AppNav from "@/components/AppNav.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="GitSyntropy | Landing">
  <!-- Ambient Background Effects -->
  <div class="fixed inset-0 z-0 pointer-events-none">
    <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-primary/20 blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-accent-teal/10 blur-[100px] animate-float"></div>
    <div class="absolute top-[40%] left-[20%] w-[30%] h-[30%] rounded-full bg-primary/10 blur-[90px]"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-30"></div>
  </div>

  <AppNav />
  
  <main class="relative z-10 flex flex-col w-full max-w-[1400px] mx-auto px-4 md:px-8 pt-32 pb-20">
    <!-- Hero Section -->
    <section class="flex flex-col items-center justify-center min-h-[80vh] text-center gap-8 relative">
      <!-- Decorative Crosshairs -->
      <div class="absolute top-0 left-0 text-gray-600 opacity-50 text-xs font-mono">+ 001</div>
      <div class="absolute bottom-0 right-0 text-gray-600 opacity-50 text-xs font-mono">+ 002</div>

      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-xs font-mono mb-4 animate-fade-in">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
        </span>
        SYSTEM STATUS: OPTIMAL
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold leading-[0.9] tracking-tighter max-w-5xl mx-auto bg-clip-text text-transparent bg-gradient-to-br from-white via-white to-gray-500 font-display animate-fade-in-up delay-100">
        Predict Team <br/>
        <span class="text-primary text-glow">Compatibility</span>
      </h1>

      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed animate-fade-in-up delay-200">
        Multi-agent system that scores how well developers will work together -- before they do. Combines GitHub behavioral data with psychometric profiling to surface concrete risks, not just numbers.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-6 animate-fade-in-up delay-300">
        <a href="/dashboard" class="btn btn-primary px-8 py-4 text-lg">
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
          Run Team Analysis
        </a>
        <a href="/auth" class="btn btn-secondary px-8 py-4 text-lg">
          <span class="material-symbols-outlined">hub</span>
          Connect GitHub
        </a>
      </div>
      
      <!-- Hero Image / 3D Abstract -->
      <div class="w-full max-w-4xl mt-16 relative">
        <div class="absolute -top-10 -right-10 w-24 h-24 border-t border-r border-primary/30 rounded-tr-3xl hidden md:block"></div>
        <div class="absolute -bottom-10 -left-10 w-24 h-24 border-b border-l border-primary/30 rounded-bl-3xl hidden md:block"></div>
        
        <div class="glass-panel rounded-none p-2 border-white/40 relative overflow-hidden group">
          <div class="relative rounded-none overflow-hidden bg-[#0A0A0B] aspect-[16/9]">
            <img src="/demo.gif" alt="GitSyntropy dashboard demo" class="absolute top-0 right-0 h-full w-auto max-w-none" style="object-fit: cover; object-position: right top;" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0B]/50 via-transparent to-transparent pointer-events-none"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof -->
    <section class="py-12 border-y border-white/40 my-12 animate-fade-in-up delay-400">
      <p class="text-center text-gray-500 text-sm mb-8 font-mono">BUILT WITH</p>
      <div class="flex flex-wrap justify-center gap-10 opacity-60 hover:opacity-100 transition-all duration-500">
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </span>
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-[#009688]"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zM9.8 17.2l-5-5 1.4-1.4 3.6 3.6 7.6-7.6 1.4 1.4-9 9z"/></svg>
          FastAPI
        </span>
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-[#3ECF8E]"><path d="M11.9 1.036c-.015-.986-1.26-1.41-1.874-.637L.764 12.05C.296 12.636.754 13.5 1.5 13.5h9.5l.185 9.494c.015.986 1.274 1.41 1.875.637l9.262-11.547c.468-.586.01-1.451-.736-1.451H12.086L11.9 1.036z"/></svg>
          Supabase
        </span>
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-[#D97757]"><path d="M4.5 0h15A4.5 4.5 0 0 1 24 4.5v15a4.5 4.5 0 0 1-4.5 4.5h-15A4.5 4.5 0 0 1 0 19.5v-15A4.5 4.5 0 0 1 4.5 0z"/><path fill="#fff" d="M7.7 17.4V6.6h2.7l2.6 6.4 2.6-6.4h2.7v10.8h-2.1V9.6l-2.9 7.8h-.6l-2.9-7.8v7.8z"/></svg>
          Anthropic
        </span>
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white"><path d="M12 3L1 9l11 6 9-4.91V17h2V9zM5 13.18v4L12 21l7-3.82v-4L12 17z"/></svg>
          LangGraph
        </span>
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white"><path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.594-7.305h.003z"/></svg>
          Vercel
        </span>
        <span class="text-sm font-bold text-white flex items-center gap-2 font-mono">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-[#B835FF]"><path d="M0 12C0 5.373 5.373 0 12 0s12 5.373 12 12-5.373 12-12 12S0 18.627 0 12zm12-6a6 6 0 1 0 0 12A6 6 0 0 0 12 6z"/></svg>
          Railway
        </span>
      </div>
    </section>

    <!-- Bento Grid Features -->
    <section class="py-20 animate-fade-in-up delay-500">
      <div class="flex flex-col gap-4 mb-12">
        <h2 class="text-3xl md:text-5xl font-bold font-display">Behavioral signals, <br/><span class="text-gray-500">not just commit counts.</span></h2>
        <p class="text-gray-400 max-w-xl">GitSyntropy combines GitHub telemetry with psychometric profiling to surface compatibility risks that activity metrics alone miss.</p>
      </div>
      
      <div class="bento h-auto md:h-[600px]">
        <!-- Card 1: Large Integration -->
        <div class="col-8 glass-card rounded-none p-8 relative overflow-hidden group glass-card-hover h-full">
          <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative z-10 flex flex-col justify-between h-full">
            <div>
              <div class="w-12 h-12 rounded-lg bg-white/5 border border-white/40 flex items-center justify-center mb-4 text-white">
                <span class="material-symbols-outlined">hub</span>
              </div>
              <h3 class="text-2xl font-bold mb-2 font-display">Seamless Integration</h3>
              <p class="text-gray-400 max-w-sm">Connects instantly with GitHub to ingest workflow data without friction.</p>
            </div>
            <div class="mt-8 flex gap-4">
              <div class="px-4 py-2 rounded-lg bg-[#24292e] flex items-center gap-2 text-sm font-mono border border-gray-700">
                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                git_connect_status: OK
              </div>
            </div>
          </div>
        </div>
        
        <!-- Card 2: Burnout Prevention -->
        <div class="col-4 glass-card rounded-none p-8 relative overflow-hidden group glass-card-hover flex flex-col h-full">
          <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-accent-teal/10 to-transparent"></div>
          <div class="w-12 h-12 rounded-lg bg-white/5 border border-white/40 flex items-center justify-center mb-4 text-accent-teal">
            <span class="material-symbols-outlined">schedule</span>
          </div>
          <h3 class="text-2xl font-bold mb-2 font-display">Chronotype Sync</h3>
          <p class="text-gray-400 mb-8">Detect peak-hour overlap gaps. Flag teams where async-first is the safer working model.</p>
          <div class="flex-1 w-full rounded-none overflow-hidden relative min-h-[120px]">
            <img src="/sync.png" alt="GitHub sync panel" class="w-full h-full object-cover object-top" />
          </div>
        </div>
      </div>
    </section>

    <!-- Process Flow -->
    <section class="py-24 relative">
      <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white/10 to-transparent md:block hidden"></div>
      <div class="text-center mb-16 relative z-10">
        <span class="text-primary font-mono text-sm uppercase tracking-widest mb-2 block">Pipeline</span>
        <h2 class="text-4xl font-bold font-display">From GitHub signals to <span class="text-white drop-shadow-[0_0_10px_rgba(255,255,255,0.3)]">team insight</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
        <div class="flex flex-col items-center text-center group">
          <div class="w-20 h-20 rounded-none glass-panel flex items-center justify-center mb-6 border border-white/40 group-hover:border-primary/50 transition-colors shadow-[0_0_30px_rgba(0,0,0,0.5)]">
            <span class="material-symbols-outlined text-4xl text-gray-300 group-hover:text-primary transition-colors">dataset_linked</span>
          </div>
          <h3 class="text-xl font-bold mb-2 font-display">1. Sync GitHub</h3>
          <p class="text-gray-400 text-sm max-w-xs">The GitHub Analyst agent extracts commit timing, PR activity, chronotype, and collaboration frequency.</p>
        </div>
        <div class="flex flex-col items-center text-center group">
          <div class="w-20 h-20 rounded-none glass-panel flex items-center justify-center mb-6 border border-white/40 group-hover:border-accent-teal/50 transition-colors shadow-[0_0_30px_rgba(0,0,0,0.5)]">
            <span class="material-symbols-outlined text-4xl text-gray-300 group-hover:text-accent-teal transition-colors">psychology</span>
          </div>
          <h3 class="text-xl font-bold mb-2 font-display">2. Profile + Score</h3>
          <p class="text-gray-400 text-sm max-w-xs">An adaptive psychometric assessment builds an 8-dimension behavioral profile. The compatibility engine scores variance across the team.</p>
        </div>
        <div class="flex flex-col items-center text-center group">
          <div class="w-20 h-20 rounded-none glass-panel flex items-center justify-center mb-6 border border-white/40 group-hover:border-accent-green/50 transition-colors shadow-[0_0_30px_rgba(0,0,0,0.5)]">
            <span class="material-symbols-outlined text-4xl text-gray-300 group-hover:text-accent-green transition-colors">auto_awesome</span>
          </div>
          <h3 class="text-xl font-bold mb-2 font-display">3. Synthesize</h3>
          <p class="text-gray-400 text-sm max-w-xs">Claude streams a narrative report: risks, hiring recommendations, and async workflow adjustments -- specific to your team's data.</p>
        </div>
      </div>
    </section>

    <!-- Navigate the Platform -->
    <section class="py-20">
      <div class="flex flex-col gap-4 mb-12">
        <span class="text-primary font-mono text-xs uppercase tracking-widest">Navigate the Platform</span>
        <h2 class="text-3xl md:text-5xl font-bold font-display">Everything you need, <br/><span class="text-gray-500">one platform.</span></h2>
        <p class="text-gray-400 max-w-xl">Five purpose-built views that run in sequence: GitHub sync, adaptive assessment, scoring, workspace orchestration, and Claude synthesis.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        <a href="/dashboard" class="glass-card rounded-none p-6 flex flex-col gap-4 border border-white/5 hover:border-primary/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-primary text-[20px]">dashboard</span>
          </div>
          <div>
            <h3 class="font-bold text-white mb-1 font-display">Dashboard</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Run multi-agent team analysis and view compatibility scores at a glance.</p>
          </div>
          <span class="text-xs font-bold text-primary group-hover:text-white transition-colors uppercase tracking-wider mt-auto flex items-center gap-1">
            Open <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </span>
        </a>
        <a href="/assessment" class="glass-card rounded-none p-6 flex flex-col gap-4 border border-white/5 hover:border-accent-teal/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-accent-teal/10 border border-accent-teal/20 flex items-center justify-center group-hover:bg-accent-teal/20 transition-colors">
            <span class="material-symbols-outlined text-accent-teal text-[20px]">psychology</span>
          </div>
          <div>
            <h3 class="font-bold text-white mb-1 font-display">Assessment</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Complete your 8-dimension psychometric profile used in compatibility scoring.</p>
          </div>
          <span class="text-xs font-bold text-accent-teal group-hover:text-white transition-colors uppercase tracking-wider mt-auto flex items-center gap-1">
            Start <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </span>
        </a>
        <a href="/compatibility" class="glass-card rounded-none p-6 flex flex-col gap-4 border border-white/5 hover:border-purple-400/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-purple-400/10 border border-purple-400/20 flex items-center justify-center group-hover:bg-purple-400/20 transition-colors">
            <span class="material-symbols-outlined text-purple-400 text-[20px]">compare_arrows</span>
          </div>
          <div>
            <h3 class="font-bold text-white mb-1 font-display">Compatibility</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Compute pairwise compatibility scores across 8 behavioral dimensions.</p>
          </div>
          <span class="text-xs font-bold text-purple-400 group-hover:text-white transition-colors uppercase tracking-wider mt-auto flex items-center gap-1">
            Compare <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </span>
        </a>
        <a href="/workspace" class="glass-card rounded-none p-6 flex flex-col gap-4 border border-white/5 hover:border-amber-400/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-amber-400/10 border border-amber-400/20 flex items-center justify-center group-hover:bg-amber-400/20 transition-colors">
            <span class="material-symbols-outlined text-amber-400 text-[20px]">schema</span>
          </div>
          <div>
            <h3 class="font-bold text-white mb-1 font-display">Workspace</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Create teams, invite members, and run the full LangGraph synthesis pipeline.</p>
          </div>
          <span class="text-xs font-bold text-amber-400 group-hover:text-white transition-colors uppercase tracking-wider mt-auto flex items-center gap-1">
            Build <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </span>
        </a>
        <a href="/insights" class="glass-card rounded-none p-6 flex flex-col gap-4 border border-white/5 hover:border-accent-neon/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-accent-neon/10 border border-accent-neon/20 flex items-center justify-center group-hover:bg-accent-neon/20 transition-colors">
            <span class="material-symbols-outlined text-accent-neon text-[20px]">auto_awesome</span>
          </div>
          <div>
            <h3 class="font-bold text-white mb-1 font-display">Insights</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Read your AI-generated team narrative, scored and structured by Claude.</p>
          </div>
          <span class="text-xs font-bold text-accent-neon group-hover:text-white transition-colors uppercase tracking-wider mt-auto flex items-center gap-1">
            Explore <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </span>
        </a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="glass-panel rounded-3xl p-12 md:p-20 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-primary/20 via-transparent to-accent-teal/20 opacity-30"></div>
        <div class="absolute -top-[50%] -left-[10%] w-[150%] h-[200%] bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent animate-spin-slow pointer-events-none" style="animation-duration: 20s;"></div>
        <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center gap-6">
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight font-display">Run your first analysis.</h2>
          <p class="text-lg text-gray-300">Run the full analysis pipeline -- GitHub sync, adaptive assessment, compatibility scoring, Claude synthesis.</p>
          <a href="/auth" class="mt-4 group relative px-8 py-4 bg-white text-black hover:bg-gray-100 rounded-none font-bold transition-all overflow-hidden font-display">
            <span class="relative z-10 flex items-center gap-2">
              Open Dashboard
              <span class="material-symbols-outlined text-sm font-bold">arrow_forward</span>
            </span>
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <!-- Footer -->
  <footer class="border-t border-white/40 bg-[#050506] pt-16 pb-8 relative z-10">
    <div class="max-w-[1400px] mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-white/40">
        <p class="text-xs text-gray-600">© 2026 GitSyntropy Inc. All rights reserved.</p>
        <div class="flex gap-4">
          <a class="text-gray-600 hover:text-white transition-colors" href="#"><span class="text-sm">Twitter/X</span></a>
          <a class="text-gray-600 hover:text-white transition-colors" href="#"><span class="text-sm">GitHub</span></a>
          <a class="text-gray-600 hover:text-white transition-colors" href="#"><span class="text-sm">LinkedIn</span></a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>