---
import SideNav from "@/components/SideNav.astro";
import { AssessmentClient } from "@/components/AssessmentClient";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="GitSyntropy | Assessment">
  <!-- Ambient Mesh Background -->
  <div class="fixed inset-0 z-0 pointer-events-none">
    <div class="absolute top-[-20%] left-[-10%] w-[900px] h-[900px] rounded-full bg-[radial-gradient(circle_at_center,_rgba(204,255,0,0.15),_transparent_70%)] blur-[100px] animate-pulse-slow"></div>
    <div class="absolute bottom-[-10%] right-[-5%] w-[600px] h-[600px] rounded-full bg-[radial-gradient(circle_at_center,_rgba(50,20,90,0.3),_transparent_70%)] blur-[80px]"></div>
    <div class="absolute inset-0 opacity-[0.03] bg-grid-pattern"></div>
  </div>

  <SideNav />
  <div class="lg:ml-[220px]">
    <AssessmentClient client:load />
  </div>
</BaseLayout>
