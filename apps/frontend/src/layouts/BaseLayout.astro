---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans:wght@400;500;700&family=Reenie+Beanie&display=swap" rel="stylesheet" />
    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background-dark text-white overflow-x-hidden selection:bg-primary selection:text-white">
    <slot />
    <script>
      // Pre-warm the backend on every page load (Render free tier sleeps after 15 min)
      const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8000/api/v1";
      fetch(`${API_BASE}/health`, { method: "GET", cache: "no-store" }).catch(() => {});
    </script>
  </body>
</html>
